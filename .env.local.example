# Copy to .env.local and fill in

# Grab from console.anthropic.com (free $5 credit on signup)
ANTHROPIC_API_KEY=

# Grab from resend.com (free tier covers 100 emails/day, 3000/month)
# Used by the agent's send_message_to_parham tool. Without this, the tool
# politely tells the visitor to email Parham directly instead.
RESEND_API_KEY=

# Optional. Until you verify a custom domain in Resend, leave this empty
# (default is "Portfolio Agent <onboarding@resend.dev>"). Once parhamkhoshsolat.com
# is verified in the Resend dashboard, set this to e.g.
# RESEND_FROM=Portfolio Agent <agent@parhamkhoshsolat.com>
RESEND_FROM=
